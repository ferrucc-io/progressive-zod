{
  "name": "progressive-zod",
  "version": "1.4.3",
  "description": "Runtime type observability for TypeScript — progressively replace `any` with real Zod schemas",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    }
  },
  "bin": {
    "progressive-zod": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "test:watch": "vitest",
    "release:minor": "./scripts/release-minor.sh"
  },
  "files": [
    "dist",
    ".claude/commands"
  ],
  "keywords": [
    "zod",
    "typescript",
    "runtime",
    "observability",
    "schema",
    "inference",
    "progressive"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferrucc-io/progressive-zod.git"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ioredis": "^5.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  }
}
